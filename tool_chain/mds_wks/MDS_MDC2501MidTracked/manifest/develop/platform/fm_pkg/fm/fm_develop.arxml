                        <SW-COMPONENT-PROTOTYPE>
                          <SHORT-NAME>diag_agent</SHORT-NAME>
                          <TYPE-TREF DEST="ADAPTIVE-APPLICATION-SW-COMPONENT-TYPE">/HuaweiMDC/PlatformApplication/DiagAgentApplication/SwComponent/diag_agent</TYPE-TREF>
