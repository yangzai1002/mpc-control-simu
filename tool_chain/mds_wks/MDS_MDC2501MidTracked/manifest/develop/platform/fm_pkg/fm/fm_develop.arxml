<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_00048.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>HuaweiMDC</SHORT-NAME>
      <AR-PACKAGES>
        <AR-PACKAGE>
          <SHORT-NAME>PlatformApplication</SHORT-NAME>
          <AR-PACKAGES>
            <AR-PACKAGE>
              <SHORT-NAME>FmApplication</SHORT-NAME>
              <AR-PACKAGES>
                <AR-PACKAGE>
                  <SHORT-NAME>Execution</SHORT-NAME>
                  <ELEMENTS>
                    <EXECUTABLE>
                      <SHORT-NAME>fm</SHORT-NAME>
                      <ROOT-SW-COMPONENT-PROTOTYPE>
                        <SHORT-NAME>fm</SHORT-NAME>
                        <APPLICATION-TYPE-TREF DEST="ADAPTIVE-APPLICATION-SW-COMPONENT-TYPE">/HuaweiMDC/PlatformApplication/FmApplication/SwcComponent/fm</APPLICATION-TYPE-TREF>
                      </ROOT-SW-COMPONENT-PROTOTYPE>
                    </EXECUTABLE>
                    <EXECUTABLE>
                      <SHORT-NAME>fm_sea</SHORT-NAME>
                      <ROOT-SW-COMPONENT-PROTOTYPE>
                        <SHORT-NAME>fm</SHORT-NAME>
                        <APPLICATION-TYPE-TREF DEST="ADAPTIVE-APPLICATION-SW-COMPONENT-TYPE">/HuaweiMDC/PlatformApplication/FmApplication/SwcComponent/fm</APPLICATION-TYPE-TREF>
                      </ROOT-SW-COMPONENT-PROTOTYPE>
                    </EXECUTABLE>
                  </ELEMENTS>
                </AR-PACKAGE>
                <AR-PACKAGE S="">
                  <SHORT-NAME>SwcComponent</SHORT-NAME>
                  <ELEMENTS>
                    <ADAPTIVE-APPLICATION-SW-COMPONENT-TYPE>
                      <SHORT-NAME>fm</SHORT-NAME>
                      <PORTS>
                        <P-PORT-PROTOTYPE>
                          <SHORT-NAME>FmLowPowerNotifyPPort</SHORT-NAME>
