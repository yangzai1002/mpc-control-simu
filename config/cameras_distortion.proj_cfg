
# ****1.相机命名方式按照相机视角朝向(不是安装位置)。
# ****2.相机名字没有强制要求，相机按照如下顺序前相机(front)放在第一个，做左前(left_front)相机放在第二个排列,以此类推 。
# ****3.一定保证list有6个相机，如果实车实际安装了一个相机，其他相机可以复制粘贴补全六个相机，有对应字段就行。
# ****4.实际感知只会用到"camera_names" list里边的相机参数，所以下边可以添加额外模块所需的鱼眼相机等参数，但是不要放在camera_names 列表里。
camera_names: [ "front_120","left_front_100","right_front_100","left_back_100","right_back_100","back_120"] 
# 注意，必须和上面的 camera_names 中的内容一一对应，否则会读取出错。下边的相机数量可以大于camera_names 里的内容
#  t=y,z,-x
# front:
#   new_Size: [640, 320]
#   scaled_Size: [1920, 1080] #
#   new_K: [320, 0, 320, 0, 320, 160, 0, 0, 1]
#   Size: [1920, 1080] # *实际用到参数* 图像长宽
#   K: [4.3878290808172722e+04, 0.0, 9.6395378079781199e+02, 0.0, 4.3954549787974014e+04, 5.0627688349582581e+02, 0.0, 0.0, 1.0]  # *实际用到参数* 相机内参
#   D: [-2.3595720089315769e+01, -3.1043829066213279e+03, 2.1817720335965024e-01, 6.9653542687101902e-02]           # *实际用到参数* 相机畸变参数       
#   Epsilon: 2.0550347152246413e+01 # *实际用到参数*  相机 Epsilon
#   t: [0.00, 1.46, -1.75] # *实际用到参数*  相机外参平移
#   R_euler: [-4.03, -0.5, -0.23] # *实际用到参数*  相机外参旋转
#   vcs_to_ground_height: 0.33 # *实际用到参数*  标定时自车坐标系到地面物理地面高度
#   base_euler: 0.0
front_120:
  new_Size: [640, 320]
  scaled_Size: [1920, 1080]
  new_K: [320.0, 0.0, 320.0, 0.0, 320.0, 160.0, 0.0, 0.0, 1.0]
  Size: [3840, 2160]
  K: [7528.221452943453, 0, 1907.2428438546267, 0, 7530.664688252793, 1060.7082310733429,
    0, 0, 1]
  D: [0.20443429176341257, 1.122879609854733, 0.004422440920253438, 0.004822984421130795]
  Epsilon: 2.9562013353376244
  t: [0, 1.32, -2.53]
  R_euler: [2.06, 1.23, 1.05]
  vcs_to_ground_height: 0.0
  base_euler: 0.0
