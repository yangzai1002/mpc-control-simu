        view_right_bottom_y: 1080
      - name: left_front_around
        crop_left_top_x: 0
        crop_left_top_y: 0
        crop_right_bottom_x: 0
        crop_right_bottom_y: 0
        view_left_top_x: 0
        view_left_top_y: 0
        view_right_bottom_x: 320
